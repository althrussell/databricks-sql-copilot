# Databricks connection — local development only
# Copy this file to .env.local and fill in your values.
#
# See docs/07_DEPLOYMENT.md for full details.

# Workspace URL (include https://)
DATABRICKS_HOST=https://YOUR_WORKSPACE.cloud.databricks.com

# Personal access token for local dev
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# SQL warehouse ID (last segment of HTTP path)
DATABRICKS_WAREHOUSE_ID=YOUR_WAREHOUSE_ID

# Databricks Lakebase (Prisma) — Neon-compatible Postgres
# Uses the dbsql_copilot schema (not public).
# For Databricks Apps deployment, inject from secret scope:
#   databricks secrets put-secret inspire-secrets DATABASE_URL
#   databricks secrets put-secret inspire-secrets DIRECT_DATABASE_URL

# Pooler URL (runtime):
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.database.REGION.cloud.databricks.com/databricks_postgres?sslmode=require&schema=dbsql_copilot
# Direct URL (migrations):
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST.database.REGION.cloud.databricks.com/databricks_postgres?sslmode=require&schema=dbsql_copilot
